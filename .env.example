# Copy to .env and adjust.
# Leave DATABASE_URL unset to use the embedded PostgreSQL (recommended for end users).
# Set DATABASE_URL to use an external PostgreSQL instance (Docker Compose for devs).

# DATABASE_URL=postgres://yaf:yaf@localhost:5433/yaf

# API server bind address
API_HOST=127.0.0.1
API_PORT=3001

# Log level: trace | debug | info | warn | error
RUST_LOG=info
